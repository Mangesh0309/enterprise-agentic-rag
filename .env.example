APP_NAME="Enterprise Agentic RAG"
APP_ENV=local
API_PREFIX=/api
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/enterprise_rag
SYNC_DATABASE_URL=postgresql://rag:rag@postgres:5432/enterprise_rag

CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=enterprise_knowledge

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_REQUEST_TIMEOUT=120

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32

TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

RETRIEVAL_TOP_K=6
HYBRID_DENSE_WEIGHT=0.65
HYBRID_BM25_WEIGHT=0.35
CHUNK_SIZE=900
CHUNK_OVERLAP=120
MAX_REFLECTION_CYCLES=2
MIN_VERIFICATION_SCORE=0.72

LOG_LEVEL=INFO
